# Copy this file to ".env" and edit. Never commit the real .env.

# Admin dashboard password (CHANGE THIS)
ADMIN_PASSWORD=change-me-please

# Flask session secret (any long random string)
SECRET_KEY=replace-with-a-long-random-string

# Product / pricing
PRICE=9.99
LIST_PRICE=29.99
CURRENCY=USD

# Seller details shown on receipts
SELLER_NAME=Vital Theory
SELLER_EMAIL=hello@vitaltheory.shop
SELLER_SITE=vitaltheory.shop

# Public base URL (used for Stripe redirect URLs)
BASE_URL=http://127.0.0.1:5000

# ---- Real payments (optional) ----
# Leave STRIPE_SECRET_KEY empty to run in DEMO mode (simulated payments).
# Add your Stripe secret key to take real card payments via Stripe's hosted
# checkout page (customers enter cards on Stripe, never on this site).
# Requires: pip install stripe
STRIPE_SECRET_KEY=

# ---- Supabase (order database) ----
# Leave both blank to use local SQLite. Set both to persist orders to Supabase.
# First run store/supabase_schema.sql in your Supabase SQL editor to create the
# table. Use the SERVICE ROLE key here for production (orders contain PII).
SUPABASE_URL=
SUPABASE_KEY=
